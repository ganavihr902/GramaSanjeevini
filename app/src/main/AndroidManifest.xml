<?xml version="1.0" encoding="utf-8"?>

<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.gramasanjeevini">

    <!-- Internet Permission -->

    <uses-permission
        android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.GramaSanjeevini">

        <!-- Splash Screen -->

        <activity
            android:name=
                ".activities.MainActivity"
            android:exported="true">

            <intent-filter>

                <action
                    android:name=
                        "android.intent.action.MAIN" />

                <category
                    android:name=
                        "android.intent.category.LAUNCHER" />

            </intent-filter>

        </activity>

        <!-- Login -->

        <activity
            android:name=
                ".activities.LoginActivity" />

        <!-- Signup -->

        <activity
            android:name=
                ".activities.SignupActivity" />

        <!-- User Dashboard -->

        <activity
            android:name=
                ".activities.UserDashboardActivity" />

        <!-- Pharmacist Dashboard -->

        <activity
            android:name=
                ".activities.PharmacistDashboardActivity" />

        <!-- Search Medicine -->

        <activity
            android:name=
                ".activities.SearchMedicineActivity" />

        <!-- Result Activity -->

        <activity
            android:name=
                ".activities.ResultActivity" />

        <!-- Medicine Details -->

        <activity
            android:name=
                ".activities.MedicineDetailsActivity" />

    </application>

</manifest>